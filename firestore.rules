rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🌍 1. Public Feed: Anyone can view the aggregated cards
    match /posts/{postId} {
      allow read: if true;
      allow write: if false; // Only written by Server Cron via Admin SDK
    }

    // 🛡️ 2. Admin Only: Fully locks master sources configuration (Both read & write)
    match /sources/{sourceId} {
      allow read, write: if request.auth != null && request.auth.token.email == "nizanmalkit@gmail.com";
    }

    // 👤 3. Personal Accounts: Users can read/write ONLY their own bookmarks & news preference
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ⚙️ 4. Global configurations
    match /settings/sync_config {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "nizanmalkit@gmail.com";
    }
  }
}
